#!/usr/bin/env bash

set -euo pipefail

VERSION="0.3.0"
COMMAND=""
INTERACTIVE="auto"

SSH_USER="root"
SSH_PORT="22"
SSH_PRIVATE_KEY="~/.ssh/id_ed25519"
SSH_PUBLIC_KEY="~/.ssh/id_ed25519.pub"
DEPLOY_USER="deployer"
TIMEZONE_VALUE="Asia/Jakarta"
SWAP_SIZE="2G"
TRAEFIK_EMAIL=""
TRAEFIK_CHALLENGE="http"
TRAEFIK_DNS_PROVIDER="cloudflare"
COMPONENT_SELECTION="all"
COMPONENT_TAGS=""
COMPONENT_SUMMARY=""
SERVER_SPECS=""
SERVER_COUNT="0"
RUN_ROOT=".civa/runs"
RUN_ID=""
GENERATED_DIR=""
INVENTORY_FILE=""
VARS_FILE=""
PLAN_FILE=""
DISPLAY_MODE=""
PROGRESS_CURRENT="0"
PROGRESS_TOTAL="4"
COMPLETED_PHASES=""

SSH_USER_PROVIDED="false"
SSH_PORT_PROVIDED="false"
SSH_PRIVATE_KEY_PROVIDED="false"
SSH_PUBLIC_KEY_PROVIDED="false"
DEPLOY_USER_PROVIDED="false"
TIMEZONE_PROVIDED="false"
TRAEFIK_EMAIL_PROVIDED="false"
TRAEFIK_CHALLENGE_PROVIDED="false"
TRAEFIK_DNS_PROVIDER_PROVIDED="false"
COMPONENTS_PROVIDED="false"
PLAN_FILE_PROVIDED="false"
SERVERS_PROVIDED="false"

usage() {
  cat <<'EOF'
Usage:
  civa <command> [options]

Commands:
  apply                        Run the Ansible playbook against the selected servers
  plan                         Generate inventory, vars, and the execution plan only
  preview                      Run ansible-playbook in check mode with diff output
  doctor                       Check whether the local machine is ready to run civa
  version                      Show the civa version
  help                         Show this help message

Options:
  --non-interactive            Disable prompts and rely on provided flags
  --ssh-user <name>            SSH user used to connect to every target server
  --ssh-port <port>            SSH port used to connect to every target server
  --ssh-private-key <path>     Local private key path used by Ansible for SSH
  --ssh-public-key <path>      Local public key path that will be installed for the deploy user
  --deployer-user <name>       User created and configured on the target servers
  --timezone <tz>              Timezone applied to the target servers
  --components <list>          Components to run: all or a comma list such as 1,2,4 or docker,traefik
  --server <addr[,hostname]>   Add a target server; hostname is optional and becomes the server hostname
  --traefik-email <email>      Email used by Let's Encrypt ACME
  --traefik-challenge <type>   Traefik challenge type: http or dns
  --traefik-dns-provider <id>  DNS provider name used when challenge type is dns
  --output <path>              Markdown summary path (default: .civa/runs/<timestamp>/plan.md)
  --help                       Show this help message

Examples:
  civa apply
  civa preview --server 203.0.113.10,edge-01 --components all
  civa plan --non-interactive --server 203.0.113.10,web-01 --server 203.0.113.11,api-01 --components 1,2,3,4
EOF
}

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

log() {
  printf '%s\n' "$1" >&2
}

print_section() {
  printf '\n== %s ==\n' "$1" >&2
  printf '%s\n' '----------------------------------------' >&2
}

progress_step() {
  PROGRESS_CURRENT=$((PROGRESS_CURRENT + 1))
  printf '[%s/%s] %s\n' "$PROGRESS_CURRENT" "$PROGRESS_TOTAL" "$1"
}

append_completed_phase() {
  if [ -z "$COMPLETED_PHASES" ]; then
    COMPLETED_PHASES="- $1"
  else
    COMPLETED_PHASES="$COMPLETED_PHASES
- $1"
  fi
}

validate_port() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
  esac

  [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

validate_positive_int() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
  esac

  [ "$1" -gt 0 ]
}

expand_home_path() {
  case "$1" in
    \~/*)
      printf '%s/%s' "$HOME" "${1#\~/}"
      ;;
    *)
      printf '%s' "$1"
      ;;
  esac
}

prompt_with_default() {
  local label="$1"
  local default_value="$2"
  local answer=""

  if [ -n "$default_value" ]; then
    printf '%s [%s]: ' "$label" "$default_value" >&2
  else
    printf '%s: ' "$label" >&2
  fi

  IFS= read -r answer
  printf '%s' "${answer:-$default_value}"
}

prompt_yes_no() {
  local label="$1"
  local default_value="$2"
  local answer=""

  while :; do
    printf '%s [%s]: ' "$label" "$default_value" >&2
    IFS= read -r answer
    answer="${answer:-$default_value}"
    answer="$(printf '%s' "$answer" | tr '[:upper:]' '[:lower:]')"

    case "$answer" in
      y|yes|n|no)
        printf '%s' "$answer"
        return 0
        ;;
    esac

    printf '%s\n' 'Please answer yes or no.' >&2
  done
}

prompt_port() {
  local label="$1"
  local default_value="$2"
  local answer=""

  while :; do
    answer="$(prompt_with_default "$label" "$default_value")"
    if validate_port "$answer"; then
      printf '%s' "$answer"
      return 0
    fi
    printf '%s\n' 'Port must be an integer between 1 and 65535.' >&2
  done
}

prompt_positive_int() {
  local label="$1"
  local default_value="$2"
  local answer=""

  while :; do
    answer="$(prompt_with_default "$label" "$default_value")"
    if validate_positive_int "$answer"; then
      printf '%s' "$answer"
      return 0
    fi
    printf '%s\n' 'Please enter a positive integer.' >&2
  done
}

should_prompt() {
  if [ "$INTERACTIVE" = "false" ]; then
    return 1
  fi

  [ -t 0 ]
}

parse_command() {
  [ "$#" -gt 0 ] || return 0

  case "$1" in
    apply|plan|preview|doctor|version)
      COMMAND="$1"
      return 0
      ;;
    help)
      usage
      exit 0
      ;;
    --*)
      return 1
      ;;
    *)
      fail "unknown command: $1"
      ;;
  esac
}

normalize_component_token() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr ' _' '--'
}

component_name_for_tag() {
  case "$1" in
    system_update) printf '%s' 'System Update & Upgrade' ;;
    user_management) printf '%s' 'User Management' ;;
    ssh_hardening) printf '%s' 'SSH Hardening' ;;
    security_firewall) printf '%s' 'Security & Firewall' ;;
    system_config) printf '%s' 'System Config' ;;
    dependencies) printf '%s' 'Dependencies' ;;
    containerization) printf '%s' 'Containerization' ;;
    traefik) printf '%s' 'Reverse Proxy (Traefik)' ;;
    *) printf '%s' "$1" ;;
  esac
}

component_tag_for_token() {
  case "$(normalize_component_token "$1")" in
    all) printf '%s' 'all' ;;
    1|system-update|system-update-upgrade|system-update---upgrade|system-update-upgrade:) printf '%s' 'system_update' ;;
    2|user-management) printf '%s' 'user_management' ;;
    3|ssh-hardening) printf '%s' 'ssh_hardening' ;;
    4|security|security-firewall|firewall|fail2ban) printf '%s' 'security_firewall' ;;
    5|system-config|system-configuration|swap|timezone) printf '%s' 'system_config' ;;
    6|dependencies|packages) printf '%s' 'dependencies' ;;
    7|containerization|docker) printf '%s' 'containerization' ;;
    8|traefik|reverse-proxy|reverse-proxy-traefik) printf '%s' 'traefik' ;;
    *) return 1 ;;
  esac
}

selected_components_include() {
  local needle="$1"

  case ",$COMPONENT_TAGS," in
    *,"$needle",*) return 0 ;;
    *) return 1 ;;
  esac
}

resolve_components() {
  local raw="${COMPONENT_SELECTION:-all}"
  local token=""
  local tag=""
  local ordered_tags=""
  local seen=","

  if [ -z "$raw" ] || [ "$raw" = "all" ]; then
    COMPONENT_TAGS="system_update,user_management,ssh_hardening,security_firewall,system_config,dependencies,containerization,traefik"
  else
    raw="$(printf '%s' "$raw" | tr ';' ',')"
    raw="$(printf '%s' "$raw" | tr ' ' ',')"

    IFS=','
    for token in $raw; do
      [ -n "$token" ] || continue
      tag="$(component_tag_for_token "$token")" || fail "unknown component selection: $token"
      if [ "$tag" = "all" ]; then
        COMPONENT_TAGS="system_update,user_management,ssh_hardening,security_firewall,system_config,dependencies,containerization,traefik"
        IFS=' '
        break
      fi

      case "$seen" in
        *,"$tag",*) ;;
        *)
          if [ -z "$ordered_tags" ]; then
            ordered_tags="$tag"
          else
            ordered_tags="$ordered_tags,$tag"
          fi
          seen="$seen$tag,"
          ;;
      esac
    done
    IFS=' '

    [ -n "$COMPONENT_TAGS" ] || COMPONENT_TAGS="$ordered_tags"
  fi

  [ -n "$COMPONENT_TAGS" ] || fail 'at least one component must be selected'

  COMPONENT_SUMMARY=""
  IFS=','
  for tag in $COMPONENT_TAGS; do
    if [ -z "$COMPONENT_SUMMARY" ]; then
      COMPONENT_SUMMARY="- $(component_name_for_tag "$tag")"
    else
      COMPONENT_SUMMARY="$COMPONENT_SUMMARY
- $(component_name_for_tag "$tag")"
    fi
  done
  IFS=' '
}

component_menu() {
  cat <<'EOF' >&2
Choose which components to run.
Type 'all' or a comma-separated list of numbers/names.
  1) system_update        - update apt cache and upgrade packages
  2) user_management      - create deployer user, sudoers, SSH key
  3) ssh_hardening        - disable root login and password auth
  4) security_firewall    - ufw and fail2ban setup
  5) system_config        - timezone and swap
  6) dependencies         - git, curl, wget, htop, vim, unzip, jq, net-tools
  7) containerization     - Docker Engine and Compose plugin
  8) traefik              - /opt/traefik, docker network, compose and ACME env
EOF
}

sanitize_alias() {
  local raw="$1"
  raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"
  raw="${raw// /-}"
  raw="${raw//[^a-zA-Z0-9._-]/-}"
  printf '%s' "$raw"
}

add_server_spec() {
  local address="$1"
  local hostname="$2"

  if [ -z "$SERVER_SPECS" ]; then
    SERVER_SPECS="$address|$hostname"
  else
    SERVER_SPECS="$SERVER_SPECS
$address|$hostname"
  fi
  SERVER_COUNT=$((SERVER_COUNT + 1))
}

parse_server_flag() {
  local raw="$1"
  local address="${raw%%,*}"
  local hostname=""

  if [ "$raw" != "$address" ]; then
    hostname="${raw#*,}"
  fi

  [ -n "$address" ] || fail '--server requires an address or IP'
  add_server_spec "$address" "$hostname"
}

build_run_id() {
  date +'%Y%m%d-%H%M%S'
}

ensure_generation_paths() {
  RUN_ID="$(build_run_id)"
  GENERATED_DIR="$RUN_ROOT/$RUN_ID"
  INVENTORY_FILE="$GENERATED_DIR/inventory.yml"
  VARS_FILE="$GENERATED_DIR/vars.yml"

  if [ -n "$PLAN_FILE" ]; then
    PLAN_FILE="$(expand_home_path "$PLAN_FILE")"
  else
    PLAN_FILE="$GENERATED_DIR/plan.md"
  fi

  mkdir -p "$GENERATED_DIR"
  mkdir -p "$(dirname "$PLAN_FILE")"
}

server_alias_for_index() {
  printf 'server-%02d' "$1"
}

generate_inventory() {
  local index=0
  local address=""
  local hostname=""
  local alias=""
  local line=""

  cat > "$INVENTORY_FILE" <<EOF
all:
  children:
    civa_targets:
      hosts:
EOF

  while IFS= read -r line; do
    [ -n "$line" ] || continue
    index=$((index + 1))
    address="${line%%|*}"
    hostname="${line#*|}"
    alias="$(sanitize_alias "$hostname")"
    [ -n "$alias" ] || alias="$(server_alias_for_index "$index")"

    cat >> "$INVENTORY_FILE" <<EOF
        $alias:
          ansible_host: "$address"
          ansible_user: "$SSH_USER"
          ansible_port: $SSH_PORT
          ansible_ssh_private_key_file: "$(expand_home_path "$SSH_PRIVATE_KEY")"
EOF

    if [ -n "$hostname" ]; then
      cat >> "$INVENTORY_FILE" <<EOF
          civa_target_hostname: "$hostname"
EOF
    fi
  done <<EOF
$SERVER_SPECS
EOF
}

generate_vars_file() {
  cat > "$VARS_FILE" <<EOF
civa_deployer_user: "$DEPLOY_USER"
civa_public_key_path: "$(expand_home_path "$SSH_PUBLIC_KEY")"
civa_timezone: "$TIMEZONE_VALUE"
civa_swap_size: "$SWAP_SIZE"
civa_swap_file: "/swapfile"
civa_traefik_email: "$TRAEFIK_EMAIL"
civa_traefik_challenge: "$TRAEFIK_CHALLENGE"
civa_traefik_dns_provider: "$TRAEFIK_DNS_PROVIDER"
EOF
}

generate_plan_file() {
  local ansible_command="ansible-playbook -i $INVENTORY_FILE ansible/playbook.yml -e @$VARS_FILE"
  local servers_markdown=""
  local index=0
  local line=""
  local address=""
  local hostname=""

  if [ -n "$COMPONENT_TAGS" ]; then
    ansible_command="$ansible_command --tags $COMPONENT_TAGS"
  fi

  case "$COMMAND" in
    preview)
      ansible_command="$ansible_command --check --diff"
      ;;
    plan)
      ansible_command="$ansible_command"
      ;;
  esac

  while IFS= read -r line; do
    [ -n "$line" ] || continue
    index=$((index + 1))
    address="${line%%|*}"
    hostname="${line#*|}"
    if [ -n "$hostname" ]; then
      servers_markdown="$servers_markdown
- $address -> $hostname"
    else
      servers_markdown="$servers_markdown
- $address"
    fi
  done <<EOF
$SERVER_SPECS
EOF

  cat > "$PLAN_FILE" <<EOF
# civa Run Plan

## Mode

- Command: $COMMAND
- SSH user: $SSH_USER
- SSH port: $SSH_PORT
- SSH private key: $(expand_home_path "$SSH_PRIVATE_KEY")
- SSH public key: $(expand_home_path "$SSH_PUBLIC_KEY")
- Deployer user: $DEPLOY_USER
- Timezone: $TIMEZONE_VALUE

## Selected Components

$COMPONENT_SUMMARY

## Target Servers
$servers_markdown

## Generated Files

- Inventory: $INVENTORY_FILE
- Vars: $VARS_FILE
- Plan: $PLAN_FILE

## Command

```bash
$ansible_command
```
EOF
}

show_configuration_summary() {
  local servers_block=""
  local line=""
  local address=""
  local hostname=""

  print_section "Run Summary"
  printf 'Command: %s\n' "$COMMAND" >&2
  printf 'SSH user: %s\n' "$SSH_USER" >&2
  printf 'SSH port: %s\n' "$SSH_PORT" >&2
  printf 'SSH private key: %s\n' "$(expand_home_path "$SSH_PRIVATE_KEY")" >&2
  printf 'SSH public key: %s\n' "$(expand_home_path "$SSH_PUBLIC_KEY")" >&2
  printf 'Deployer user: %s\n' "$DEPLOY_USER" >&2
  printf 'Timezone: %s\n' "$TIMEZONE_VALUE" >&2
  printf 'Components:\n%s\n' "$COMPONENT_SUMMARY" >&2
  printf 'Servers:\n' >&2

  while IFS= read -r line; do
    [ -n "$line" ] || continue
    address="${line%%|*}"
    hostname="${line#*|}"
    if [ -n "$hostname" ]; then
      printf -- '- %s -> %s\n' "$address" "$hostname" >&2
    else
      printf -- '- %s\n' "$address" >&2
    fi
  done <<EOF
$SERVER_SPECS
EOF

  if selected_components_include traefik; then
    printf 'Traefik ACME email: %s\n' "$TRAEFIK_EMAIL" >&2
    printf 'Traefik challenge: %s\n' "$TRAEFIK_CHALLENGE" >&2
    if [ "$TRAEFIK_CHALLENGE" = "dns" ]; then
      printf 'Traefik DNS provider: %s\n' "$TRAEFIK_DNS_PROVIDER" >&2
    fi
  fi
}

run_doctor() {
  local failures=0

  print_section "civa Doctor"
  printf 'Version: %s\n' "$VERSION"

  if command -v ansible-playbook >/dev/null 2>&1; then
    printf '[ok] ansible-playbook found\n'
  else
    printf '[fail] ansible-playbook not found\n'
    failures=$((failures + 1))
  fi

  if command -v python >/dev/null 2>&1; then
    printf '[ok] python found\n'
  else
    printf '[fail] python not found\n'
    failures=$((failures + 1))
  fi

  if [ -f "ansible/playbook.yml" ]; then
    printf '[ok] ansible/playbook.yml found\n'
  else
    printf '[fail] ansible/playbook.yml missing\n'
    failures=$((failures + 1))
  fi

  if [ -f "ansible/templates/traefik-compose.yml.j2" ]; then
    printf '[ok] Traefik compose template found\n'
  else
    printf '[fail] ansible/templates/traefik-compose.yml.j2 missing\n'
    failures=$((failures + 1))
  fi

  if [ -f "ansible/templates/fail2ban-jail.local.j2" ]; then
    printf '[ok] Fail2Ban template found\n'
  else
    printf '[fail] ansible/templates/fail2ban-jail.local.j2 missing\n'
    failures=$((failures + 1))
  fi

  if [ -f "$(expand_home_path "$SSH_PRIVATE_KEY")" ]; then
    printf '[ok] SSH private key found: %s\n' "$(expand_home_path "$SSH_PRIVATE_KEY")"
  else
    printf '[fail] SSH private key not found: %s\n' "$(expand_home_path "$SSH_PRIVATE_KEY")"
    failures=$((failures + 1))
  fi

  if [ -f "$(expand_home_path "$SSH_PUBLIC_KEY")" ]; then
    printf '[ok] SSH public key found: %s\n' "$(expand_home_path "$SSH_PUBLIC_KEY")"
  else
    printf '[fail] SSH public key not found: %s\n' "$(expand_home_path "$SSH_PUBLIC_KEY")"
    failures=$((failures + 1))
  fi

  if [ "$failures" -gt 0 ]; then
    printf 'Doctor summary: %s blocker(s) found\n' "$failures"
    return 1
  fi

  printf 'Doctor summary: local machine looks ready to run civa\n'
}

run_ansible() {
  local cmd=(ansible-playbook -i "$INVENTORY_FILE" ansible/playbook.yml -e "@$VARS_FILE")

  if [ -n "$COMPONENT_TAGS" ]; then
    cmd+=(--tags "$COMPONENT_TAGS")
  fi

  case "$COMMAND" in
    preview)
      cmd+=(--check --diff)
      ;;
  esac

  progress_step "Running ansible-playbook"
  if [ "$COMMAND" = "preview" ]; then
    append_completed_phase "ansible-playbook check run"
  else
    append_completed_phase "ansible-playbook execution"
  fi

  "${cmd[@]}"
}

show_execution_summary() {
  print_section "Execution Summary"
  printf 'Command: %s\n' "$COMMAND" >&2
  printf 'Completed phases: %s/%s\n' "$PROGRESS_CURRENT" "$PROGRESS_TOTAL" >&2
  printf 'Phases completed:\n%s\n' "$COMPLETED_PHASES" >&2
  printf 'Inventory: %s\n' "$INVENTORY_FILE" >&2
  printf 'Vars: %s\n' "$VARS_FILE" >&2
  printf 'Plan: %s\n' "$PLAN_FILE" >&2

  case "$COMMAND" in
    preview)
      printf 'Result: preview completed with ansible check mode\n' >&2
      ;;
    apply)
      printf 'Result: apply completed\n' >&2
      ;;
    plan)
      printf 'Result: plan generated without executing ansible-playbook\n' >&2
      ;;
  esac
}

build_noninteractive_requirements() {
  [ "$SERVER_COUNT" -gt 0 ] || fail 'non-interactive mode requires at least one --server entry'
  [ -n "$TRAEFIK_EMAIL" ] || ! selected_components_include traefik || fail 'traefik selection requires --traefik-email'
}

interactive_collect() {
  local index=0
  local answer=""
  local address=""
  local hostname=""

  should_prompt || return 0

  print_section "Interactive Setup"
  log 'civa will ask for the minimum data needed to generate inventory, vars, and the Ansible run plan.'

  if [ -z "$COMPONENT_SELECTION" ] || [ "$COMPONENTS_PROVIDED" != "true" ]; then
    print_section "Step 1/6 - Component Selection"
    component_menu
    COMPONENT_SELECTION="$(prompt_with_default 'Components to run' 'all')"
  fi

  if [ "$SERVER_COUNT" -eq 0 ]; then
    print_section "Step 2/6 - Server Count"
    SERVER_COUNT="$(prompt_positive_int 'How many servers will be targeted?' '1')"
    SERVER_SPECS=""
    index=1
    while [ "$index" -le "$SERVER_COUNT" ]; do
      print_section "Server $index"
      address="$(prompt_with_default 'Server IP or address' '')"
      [ -n "$address" ] || fail 'server address cannot be empty'
      hostname="$(prompt_with_default 'Hostname to apply on the server (optional)' '')"
      add_server_spec "$address" "$hostname"
      index=$((index + 1))
    done
  fi

  if [ "$SSH_USER_PROVIDED" != "true" ]; then
    print_section "Step 3/6 - SSH Access"
    SSH_USER="$(prompt_with_default 'SSH user for the initial connection' "$SSH_USER")"
  fi

  if [ "$SSH_PORT_PROVIDED" != "true" ]; then
    SSH_PORT="$(prompt_port 'SSH port for the initial connection' "$SSH_PORT")"
  fi

  if [ "$SSH_PRIVATE_KEY_PROVIDED" != "true" ]; then
    SSH_PRIVATE_KEY="$(prompt_with_default 'Local SSH private key path used by Ansible' "$SSH_PRIVATE_KEY")"
  fi

  if [ "$SSH_PUBLIC_KEY_PROVIDED" != "true" ]; then
    SSH_PUBLIC_KEY="$(prompt_with_default 'Local SSH public key path to install for the deployer user' "$SSH_PUBLIC_KEY")"
  fi

  if [ "$DEPLOY_USER_PROVIDED" != "true" ]; then
    print_section "Step 4/6 - Target User"
    DEPLOY_USER="$(prompt_with_default 'Deployer username to create on the servers' "$DEPLOY_USER")"
  fi

  if [ "$TIMEZONE_PROVIDED" != "true" ]; then
    print_section "Step 5/6 - System Defaults"
    TIMEZONE_VALUE="$(prompt_with_default 'Timezone to apply on all servers' "$TIMEZONE_VALUE")"
  fi

  resolve_components

  if selected_components_include traefik; then
    print_section "Step 6/6 - Traefik"
    if [ "$TRAEFIK_EMAIL_PROVIDED" != "true" ]; then
      TRAEFIK_EMAIL="$(prompt_with_default 'ACME email for Traefik' "$TRAEFIK_EMAIL")"
    fi
    [ -n "$TRAEFIK_EMAIL" ] || fail 'Traefik requires a non-empty ACME email'

    if [ "$TRAEFIK_CHALLENGE_PROVIDED" != "true" ]; then
      while :; do
        answer="$(prompt_with_default 'Traefik challenge type (http or dns)' "$TRAEFIK_CHALLENGE")"
        answer="$(printf '%s' "$answer" | tr '[:upper:]' '[:lower:]')"
        case "$answer" in
          http|dns)
            TRAEFIK_CHALLENGE="$answer"
            break
            ;;
        esac
        log 'Challenge type must be http or dns.'
      done
    fi

    if [ "$TRAEFIK_CHALLENGE" = "dns" ] && [ "$TRAEFIK_DNS_PROVIDER_PROVIDED" != "true" ]; then
      TRAEFIK_DNS_PROVIDER="$(prompt_with_default 'Traefik DNS provider name' "$TRAEFIK_DNS_PROVIDER")"
    fi
  fi

  if [ "$PLAN_FILE_PROVIDED" != "true" ]; then
    PLAN_FILE="$(prompt_with_default 'Optional Markdown summary path (blank for default run directory)' "$PLAN_FILE")"
  fi

  show_configuration_summary

  if [ "$COMMAND" = "apply" ]; then
    answer="$(prompt_yes_no 'Continue with ansible apply after reviewing the summary?' 'yes')"
    case "$answer" in
      n|no)
        log 'civa apply was cancelled by the user before ansible-playbook started.'
        exit 0
        ;;
    esac
  fi
}

if [ "$#" -eq 0 ]; then
  usage
  exit 0
fi

if parse_command "$1"; then
  if [ "$#" -gt 0 ] && [ "${1#--}" = "$1" ]; then
    shift
  fi
fi

while [ "$#" -gt 0 ]; do
  case "$1" in
    --non-interactive)
      INTERACTIVE="false"
      shift
      ;;
    --ssh-user)
      SSH_USER="$2"
      SSH_USER_PROVIDED="true"
      shift 2
      ;;
    --ssh-port)
      SSH_PORT="$2"
      SSH_PORT_PROVIDED="true"
      shift 2
      ;;
    --ssh-private-key)
      SSH_PRIVATE_KEY="$2"
      SSH_PRIVATE_KEY_PROVIDED="true"
      shift 2
      ;;
    --ssh-public-key)
      SSH_PUBLIC_KEY="$2"
      SSH_PUBLIC_KEY_PROVIDED="true"
      shift 2
      ;;
    --deployer-user)
      DEPLOY_USER="$2"
      DEPLOY_USER_PROVIDED="true"
      shift 2
      ;;
    --timezone)
      TIMEZONE_VALUE="$2"
      TIMEZONE_PROVIDED="true"
      shift 2
      ;;
    --components)
      COMPONENT_SELECTION="$2"
      COMPONENTS_PROVIDED="true"
      shift 2
      ;;
    --server)
      parse_server_flag "$2"
      SERVERS_PROVIDED="true"
      shift 2
      ;;
    --traefik-email)
      TRAEFIK_EMAIL="$2"
      TRAEFIK_EMAIL_PROVIDED="true"
      shift 2
      ;;
    --traefik-challenge)
      TRAEFIK_CHALLENGE="$2"
      TRAEFIK_CHALLENGE_PROVIDED="true"
      shift 2
      ;;
    --traefik-dns-provider)
      TRAEFIK_DNS_PROVIDER="$2"
      TRAEFIK_DNS_PROVIDER_PROVIDED="true"
      shift 2
      ;;
    --output)
      PLAN_FILE="$2"
      PLAN_FILE_PROVIDED="true"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      fail "unknown argument: $1"
      ;;
  esac
done

case "$COMMAND" in
  version)
    printf 'civa %s\n' "$VERSION"
    exit 0
    ;;
  doctor)
    SSH_PRIVATE_KEY="$(expand_home_path "$SSH_PRIVATE_KEY")"
    SSH_PUBLIC_KEY="$(expand_home_path "$SSH_PUBLIC_KEY")"
    run_doctor
    exit $?
    ;;
  apply|plan|preview)
    ;;
  *)
    usage
    exit 0
    ;;
esac

interactive_collect
resolve_components

validate_port "$SSH_PORT" || fail '--ssh-port must be between 1 and 65535'
[ -n "$SSH_USER" ] || fail '--ssh-user must not be empty'
[ -n "$DEPLOY_USER" ] || fail '--deployer-user must not be empty'
[ -n "$TIMEZONE_VALUE" ] || fail '--timezone must not be empty'

SSH_PRIVATE_KEY="$(expand_home_path "$SSH_PRIVATE_KEY")"
SSH_PUBLIC_KEY="$(expand_home_path "$SSH_PUBLIC_KEY")"

if [ "$INTERACTIVE" = "false" ]; then
  build_noninteractive_requirements
  show_configuration_summary
fi

[ -f "$SSH_PRIVATE_KEY" ] || fail "SSH private key not found: $SSH_PRIVATE_KEY"
[ -f "$SSH_PUBLIC_KEY" ] || fail "SSH public key not found: $SSH_PUBLIC_KEY"

if selected_components_include traefik; then
  [ -n "$TRAEFIK_EMAIL" ] || fail 'Traefik requires a non-empty ACME email'
  case "$TRAEFIK_CHALLENGE" in
    http|dns) ;;
    *) fail 'Traefik challenge must be http or dns' ;;
  esac
  if [ "$TRAEFIK_CHALLENGE" = "dns" ]; then
    [ -n "$TRAEFIK_DNS_PROVIDER" ] || fail 'Traefik DNS challenge requires --traefik-dns-provider'
  fi
fi

ensure_generation_paths

PROGRESS_CURRENT="0"
COMPLETED_PHASES=""

case "$COMMAND" in
  plan)
    PROGRESS_TOTAL="3"
    ;;
  *)
    PROGRESS_TOTAL="4"
    ;;
esac

progress_step 'Generating Ansible inventory'
generate_inventory
append_completed_phase 'Inventory generated'

progress_step 'Generating Ansible vars file'
generate_vars_file
append_completed_phase 'Vars file generated'

progress_step 'Writing Markdown execution plan'
generate_plan_file
append_completed_phase 'Markdown plan generated'

case "$COMMAND" in
  plan)
    show_execution_summary
    ;;
  preview|apply)
    run_ansible
    show_execution_summary
    ;;
esac

printf 'Generated plan: %s\n' "$PLAN_FILE"
printf 'Inventory: %s\n' "$INVENTORY_FILE"
printf 'Vars: %s\n' "$VARS_FILE"
